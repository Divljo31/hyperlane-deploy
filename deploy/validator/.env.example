# Copy to deploy/validator/.env, fill in, and `chmod 600 .env`. .env is gitignored; .env.example is committed.
# SELF-HOSTED: private keys live here (hexKey). Prefer Docker secrets / a self-hosted Vault for real deployments.

# Dedicated/private Hydration RPC(s), comma-separated. Ideally your own self-hosted Hydration node. NEVER public.
HYDRATION_RPC_URLS=https://your-private-or-self-hosted-hydration-rpc

# One INDEPENDENT hex private key per validator. Each maps to an EOA that needs a little WETH on Hydration
# (one-time ValidatorAnnounce.announce() tx). Record each validator's EVM address for the multisig ISM (4c).
VALIDATOR_1_KEY=0x
VALIDATOR_2_KEY=0x
VALIDATOR_3_KEY=0x
