# Copy to deploy/relayer/.env, fill in, and `chmod 600 .env`. .env is gitignored; .env.example is committed.
# SELF-HOSTED: the relayer hex key lives here. Prefer Docker secrets / a self-hosted Vault for real deployments.

# One relayer hex key (separate from the validator keys). Its EOA must be FUNDED on every destination chain below.
RELAYER_KEY=0x

# Chains the relayer delivers between. The relayer EOA must have gas on every destination here.
RELAY_CHAINS=hydration,ethereum,base

# Dedicated/private RPC(s) per chain, comma-separated. Self-hosted nodes ideal. NEVER public endpoints.
HYDRATION_RPC_URLS=https://your-private-or-self-hosted-hydration-rpc
ETHEREUM_RPC_URLS=https://your-private-or-self-hosted-ethereum-rpc
BASE_RPC_URLS=https://your-private-or-self-hosted-base-rpc
